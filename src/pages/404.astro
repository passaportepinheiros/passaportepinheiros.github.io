---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/urls';
---

<BaseLayout
  title="Página não encontrada"
  description="A página que você procura não existe ou foi movida."
>
  <div class="container-shell flex flex-col items-center justify-center gap-8 py-24 text-center">
    <p class="font-display text-7xl font-bold text-primary opacity-30">404</p>
    <div>
      <h1 class="brand-heading text-3xl font-bold text-ink">Página não encontrada</h1>
      <p class="mt-3 text-base text-muted">A página que você procura não existe ou foi movida.</p>
    </div>
    <a href={withBase('/')} class="primary-cta brand-pill px-6 py-3 font-display text-sm font-bold uppercase tracking-wide transition">
      Voltar para o início
    </a>
  </div>
</BaseLayout>
