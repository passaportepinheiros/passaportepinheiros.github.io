---
import { getCollection } from 'astro:content';
import ExperienceExplorer from '../components/ExperienceExplorer.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories, categoryLabel, sortExperiences, type Category } from '../lib/experiences';

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: category.value },
    props: { category: category.value },
  }));
}

interface Props {
  category: Category;
}

const { category } = Astro.props;
const allExperiences = sortExperiences(await getCollection('experiencias'));
const title = categoryLabel(category);
---

<BaseLayout title={title} description={`${title} participantes do Passaporte Pinheiros.`}>
  <section class="container-shell py-12 md:py-14">
    <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">Categoria</p>
    <h1 class="mt-3 font-display text-4xl font-extrabold leading-tight text-primary md:text-5xl">{title}</h1>
  </section>

  <ExperienceExplorer experiences={allExperiences} initialCategory={category} />
</BaseLayout>
