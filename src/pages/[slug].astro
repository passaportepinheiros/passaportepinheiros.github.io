---
import { getCollection } from 'astro:content';
import { ArrowLeft, AtSign, ExternalLink, Globe, MapPin, MessageCircle, Phone, Sparkles } from '@lucide/astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  categoryLabel,
  compactDescription,
  descriptionParagraphs,
  getRelatedExperiences,
  instagramProfileUrl,
  sortExperiences,
  type Experience,
} from '../lib/experiences';
import { withBase } from '../lib/urls';

export async function getStaticPaths() {
  const experiences = await getCollection('experiencias');

  return experiences.map((experience) => ({
    params: {
      slug: experience.data.slug,
    },
    props: { experience },
  }));
}

interface Props {
  experience: Experience;
}

const { experience } = Astro.props as Props;
const { data } = experience;
const allExperiences = sortExperiences(await getCollection('experiencias'));
const related = getRelatedExperiences(experience, allExperiences, 4);
const instagramHref = instagramProfileUrl(data.instagram);
const fallbackDescription = 'Informações da experiência em atualização.';
const description = data.description ?? fallbackDescription;
const benefitDescription = data.description
  ? compactDescription(data.description, 180)
  : 'Benefício Passaporte em atualização.';
const paragraphs = descriptionParagraphs(description);
type Endereco = (typeof data.enderecos)[number];
type Telefone = Endereco['telefones'][number];

const formatEndereco = (endereco: Endereco) =>
  `${endereco.logradouro}, ${endereco.numero}`;

const googleMapsUrl = (endereco: Endereco) => {
  const query = [
    data.title,
    formatEndereco(endereco),
    endereco.bairro,
    endereco.cidade ?? 'São Paulo',
    'SP',
    'Brasil',
  ]
    .filter(Boolean)
    .join(' ');
  const params = new URLSearchParams({
    api: '1',
    query,
  });

  if (data.googlePlaceId) {
    params.set('query_place_id', data.googlePlaceId);
  }

  return `https://www.google.com/maps/search/?${params.toString()}`;
};

const primeiroEndereco = data.enderecos[0];
const localizacaoResumo = primeiroEndereco
  ? formatEndereco(primeiroEndereco)
  : 'Pinheiros, São Paulo';
const primeiroEnderecoComMapa = data.enderecos.find(
  (endereco) => typeof endereco.lat === 'number' && typeof endereco.lng === 'number',
);
const mapPoints = data.enderecos
  .filter((endereco) => typeof endereco.lat === 'number' && typeof endereco.lng === 'number')
  .map((endereco) => ({
    title: data.enderecos.length > 1 ? `${data.title} - ${formatEndereco(endereco)}` : data.title,
    address: formatEndereco(endereco),
    complement: endereco.complemento ?? '',
    lat: endereco.lat,
    lng: endereco.lng,
    mapsUrl: googleMapsUrl(endereco),
  }));

const telefoneMeta = (telefone: Telefone) => {
  const isLinkable = /^\d{10,11}$/.test(telefone.numero);

  if (!isLinkable) {
    return {
      href: '',
      label: telefone.tipo === 'whatsapp' ? 'WhatsApp' : 'Telefone',
      external: false,
    };
  }

  return telefone.tipo === 'whatsapp'
    ? {
        href: `https://wa.me/55${telefone.numero}`,
        label: 'WhatsApp',
        external: true,
      }
    : {
        href: `tel:+55${telefone.numero}`,
        label: 'Telefone',
        external: false,
      };
};

const siteOrigin = Astro.site ? new URL(Astro.site).origin : 'https://passaportepinheiros.com.br';
const pageUrl = `${siteOrigin}${withBase(`/${data.slug}/`)}`;
const ogImage = data.images?.experience ? `${siteOrigin}${withBase(data.images.experience)}` : undefined;

const schemaType = data.category === 'restaurantes' ? 'Restaurant' : 'LocalBusiness';
const sameAs = [data.website, instagramHref].filter((url): url is string => Boolean(url));
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: data.title,
  description: compactDescription(description, 200),
  url: pageUrl,
  ...(ogImage ? { image: ogImage } : {}),
  ...(sameAs.length > 0 ? { sameAs } : {}),
  address: primeiroEndereco
    ? {
        '@type': 'PostalAddress',
        streetAddress: `${primeiroEndereco.logradouro}, ${primeiroEndereco.numero}${primeiroEndereco.complemento ? `, ${primeiroEndereco.complemento}` : ''}`,
        addressLocality: primeiroEndereco.cidade ?? 'São Paulo',
        addressRegion: 'SP',
        addressCountry: 'BR',
        ...(primeiroEndereco.cep ? { postalCode: primeiroEndereco.cep } : {}),
      }
    : undefined,
  ...(primeiroEndereco?.telefones[0]
    ? { telephone: primeiroEndereco.telefones[0].formatado }
    : {}),
  ...(primeiroEnderecoComMapa
    ? {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: primeiroEnderecoComMapa.lat,
          longitude: primeiroEnderecoComMapa.lng,
        },
      }
    : {}),
};
---

<BaseLayout title={data.title} description={compactDescription(description, 156)} ogImage={ogImage} canonical={pageUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <article>
    <section class="relative overflow-hidden bg-primary text-white">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_25%_20%,rgba(255,255,255,0.22),transparent_30%),linear-gradient(135deg,var(--color-primary-strong),var(--color-primary))]"></div>
      {data.images?.experience && (
        <img
          src={withBase(data.images.experience)}
          alt={`Foto de ${data.title}`}
          class="absolute inset-0 h-full w-full object-cover opacity-45"
          loading="eager"
        />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/70 to-primary/25"></div>

      <div class="container-shell relative min-h-[420px] py-8 md:min-h-[500px] md:py-12">
        <a
          href={withBase('/')}
          class="detail-back-button focus-ring inline-flex items-center gap-2 rounded px-4 py-2 text-sm font-semibold transition"
        >
          <ArrowLeft class="h-4 w-4" aria-hidden="true" />
          Voltar
        </a>

        <div class="absolute bottom-8 left-0 right-0 px-4 md:bottom-12 md:px-0">
          <div class="container-shell px-0">
            <div class="mb-5 flex flex-wrap items-center gap-3">
              <span class="rounded bg-white px-3 py-1 font-display text-xs font-bold uppercase tracking-wide text-primary">
                {categoryLabel(data.category)}
              </span>
              {data.instagram && (
                <span class="inline-flex items-center gap-2 rounded bg-white/15 px-3 py-1 text-sm font-semibold backdrop-blur">
                  <AtSign class="h-4 w-4" aria-hidden="true" />
                  @{data.instagram}
                </span>
              )}
              {data.categoria_fsq && (
                <span class="rounded bg-white/15 px-3 py-1 text-sm font-semibold backdrop-blur">
                  {data.categoria_fsq}
                </span>
              )}
            </div>

            <div class="flex max-w-4xl items-end gap-5">
              {data.images?.logo ? (
                <img
                  src={withBase(data.images.logo)}
                  alt={`Logo de ${data.title}`}
                  class="hidden h-20 w-20 rounded-lg border border-white/70 bg-white object-contain p-2 md:block"
                />
              ) : (
                <span class="hidden h-20 w-20 shrink-0 items-center justify-center rounded-lg border border-white/70 bg-white/95 text-primary md:inline-flex">
                  <Sparkles class="h-8 w-8" aria-hidden="true" />
                </span>
              )}
              <div>
                <h1 class="font-display text-4xl font-extrabold leading-[1.05] md:text-6xl">{data.title}</h1>
                <p class="mt-4 inline-flex items-center gap-2 text-base font-semibold text-white/90">
                  <MapPin class="h-5 w-5" aria-hidden="true" />
                  {localizacaoResumo}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="container-shell grid gap-8 py-10 md:grid-cols-[1fr_360px] md:py-14">
      <div>
        <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">A experiência</p>
        <div class="mt-4 grid max-w-3xl gap-4 text-lg leading-relaxed text-muted">
          {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        {
          mapPoints.length > 0 && (
            <section class="mt-10">
              <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
                <div>
                  <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">Localização</p>
                  <h2 class="mt-2 font-display text-3xl font-extrabold text-ink">Onde encontrar</h2>
                </div>
                {mapPoints.length === 1 && (
                  <a
                    href={mapPoints[0].mapsUrl}
                    target="_blank"
                    rel="noreferrer noopener"
                    class="focus-ring inline-flex items-center gap-2 rounded border border-primary px-4 py-3 font-display text-sm font-bold uppercase tracking-wide text-primary transition hover:bg-primary hover:text-white"
                  >
                    Abrir no Google Maps
                    <ExternalLink class="h-4 w-4" aria-hidden="true" />
                  </a>
                )}
              </div>

              <div class="overflow-hidden rounded-lg border border-border bg-surface shadow-sm">
                <div
                  data-experience-map
                  data-map-points={JSON.stringify(mapPoints)}
                  class="pp-leaflet-map h-[320px] w-full bg-surface-soft md:h-[380px]"
                  aria-label={`Mapa de localização de ${data.title}`}
                />
                {mapPoints.length > 1 && (
                  <div class="grid gap-3 border-t border-border bg-surface p-4 sm:grid-cols-2">
                    {mapPoints.map((point) => (
                      <a
                        href={point.mapsUrl}
                        target="_blank"
                        rel="noreferrer noopener"
                        class="focus-ring flex items-start gap-3 rounded border border-border/70 bg-surface-soft/70 p-3 text-sm transition hover:border-primary hover:text-primary"
                      >
                        <MapPin class="mt-0.5 h-4 w-4 shrink-0 text-primary" aria-hidden="true" />
                        <span class="min-w-0">
                          <span class="block font-semibold text-ink">{point.address}</span>
                          <span class="mt-1 inline-flex items-center gap-1 font-display text-xs font-bold uppercase tracking-wide text-primary">
                            Abrir no Google Maps
                            <ExternalLink class="h-3.5 w-3.5" aria-hidden="true" />
                          </span>
                        </span>
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </section>
          )
        }
      </div>

      <aside class="rounded-lg border border-border/70 bg-surface p-6 md:self-start">
        <div class="flex items-start gap-3">
          <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded bg-primary-soft text-primary">
            <Sparkles class="h-5 w-5" aria-hidden="true" />
          </span>
          <div>
            <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">Benefício Passaporte</p>
            <p class="mt-2 text-sm leading-relaxed text-muted">{benefitDescription}</p>
          </div>
        </div>

        <div class="mt-6 grid gap-3 border-t border-border/70 pt-5">
          {instagramHref && (
            <a
              href={instagramHref}
              target="_blank"
              rel="noreferrer"
              class="focus-ring inline-flex items-center justify-center gap-2 rounded border border-primary px-4 py-3 font-display text-sm font-bold uppercase tracking-wide text-primary transition hover:bg-primary hover:text-white"
            >
              <AtSign class="h-4 w-4" aria-hidden="true" />
              Ver no Instagram
              <ExternalLink class="h-4 w-4" aria-hidden="true" />
            </a>
          )}
          {data.website && (
            <a
              href={data.website}
              target="_blank"
              rel="noreferrer noopener"
              class="focus-ring inline-flex items-center justify-center gap-2 rounded border border-border px-4 py-3 font-display text-sm font-bold uppercase tracking-wide text-muted transition hover:border-primary hover:text-primary"
            >
              <Globe class="h-4 w-4" aria-hidden="true" />
              Site oficial
              <ExternalLink class="h-4 w-4" aria-hidden="true" />
            </a>
          )}
        </div>

        {
          data.enderecos.length > 0 && (
            <div class="mt-6 border-t border-border/70 pt-5">
              <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">
                Endereços e contato
              </p>

              <div class="mt-4 grid gap-4">
                {data.enderecos.map((endereco) => (
                  <div class="rounded border border-border/70 bg-surface-soft/60 p-4">
                    <p class="flex items-start gap-2 text-sm font-semibold leading-relaxed text-ink">
                      <MapPin class="mt-0.5 h-4 w-4 shrink-0 text-primary" aria-hidden="true" />
                      <span>{formatEndereco(endereco)}</span>
                    </p>
                    {endereco.complemento && (
                      <p class="mt-1 pl-6 text-sm leading-relaxed text-muted">
                        {endereco.complemento}
                      </p>
                    )}

                    <a
                      href={googleMapsUrl(endereco)}
                      target="_blank"
                      rel="noreferrer noopener"
                      class="focus-ring mt-3 inline-flex items-center gap-2 rounded border border-border px-3 py-2 font-display text-xs font-bold uppercase tracking-wide text-primary transition hover:border-primary hover:bg-primary hover:text-white"
                    >
                      Abrir no Google Maps
                      <ExternalLink class="h-3.5 w-3.5" aria-hidden="true" />
                    </a>

                    {endereco.telefones.length > 0 && (
                      <div class="mt-3 flex flex-wrap gap-2">
                        {endereco.telefones.map((telefone) => {
                          const meta = telefoneMeta(telefone);
                          const Icon = telefone.tipo === 'whatsapp' ? MessageCircle : Phone;
                          const content = (
                            <>
                              <Icon class="h-4 w-4" aria-hidden="true" />
                              <span>{meta.label}: {telefone.formatado}</span>
                            </>
                          );

                          return meta.href ? (
                            <a
                              href={meta.href}
                              target={meta.external ? '_blank' : undefined}
                              rel={meta.external ? 'noreferrer' : undefined}
                              class="detail-contact-link focus-ring inline-flex items-center gap-2 rounded-full border px-3 py-2 text-xs font-semibold transition"
                            >
                              {content}
                            </a>
                          ) : (
                            <span class="detail-contact-link inline-flex items-center gap-2 rounded-full border px-3 py-2 text-xs font-semibold">
                              {content}
                            </span>
                          );
                        })}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </aside>
    </section>
  </article>

  {
    related.length > 0 && (
      <section class="container-shell pb-14">
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <p class="font-display text-sm font-bold uppercase tracking-wide text-primary">Também nessa categoria</p>
            <h2 class="mt-2 font-display text-3xl font-extrabold text-primary">Outras experiências</h2>
          </div>
          <a
            href={withBase(`/${data.category}/`)}
            class="hidden font-display text-sm font-bold uppercase tracking-wide text-primary hover:underline md:inline"
          >
            Ver {categoryLabel(data.category)}
          </a>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {related.map((item) => (
            <ExperienceCard experience={item} />
          ))}
        </div>
      </section>
    )
  }

  <script is:inline>
    (function () {
      var mapContainers = document.querySelectorAll('[data-experience-map]');
      if (!mapContainers.length) return;

      function ensureLeaflet() {
        if (window.L) return Promise.resolve(window.L);

        return new Promise(function (resolve) {
          var check = function () {
            if (window.L) resolve(window.L);
            else window.setTimeout(check, 50);
          };
          check();
        });
      }

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      ensureLeaflet().then(function (L) {
        mapContainers.forEach(function (container) {
          if (container.dataset.mapInitialized === 'true') return;

          var points = [];
          try {
            points = JSON.parse(container.getAttribute('data-map-points') || '[]');
          } catch {
            points = [];
          }

          if (!points.length) return;
          container.dataset.mapInitialized = 'true';

          var map = L.map(container, {
            scrollWheelZoom: false,
            zoomControl: true,
          });

          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
          }).addTo(map);

          var bounds = [];
          points.forEach(function (point) {
            if (typeof point.lat !== 'number' || typeof point.lng !== 'number') return;

            var marker = L.marker([point.lat, point.lng], { title: point.title }).addTo(map);
            marker.bindPopup(
              '<strong>' +
                escapeHtml(point.title) +
                '</strong><br><span>' +
                escapeHtml(point.address) +
                '</span><br><a href="' +
                escapeHtml(point.mapsUrl) +
                '" target="_blank" rel="noreferrer noopener">Abrir no Google Maps</a>',
            );
            bounds.push([point.lat, point.lng]);
          });

          if (bounds.length === 1) {
            map.setView(bounds[0], 16);
          } else if (bounds.length > 1) {
            map.fitBounds(bounds, { padding: [36, 36], maxZoom: 16 });
          }

          window.setTimeout(function () {
            map.invalidateSize();
          }, 0);
        });
      });
    })();
  </script>
</BaseLayout>
